# ============================================================================
# Supabase — conexión directa, sin n8n de intermediario.
# Ver db/SUPABASE_CONNECTION.md para más detalle.
#
# Mientras estas dos no estén configuradas, el dashboard usa
# automáticamente su modo demo (datos en memoria) — no hace falta nada
# más para seguir trabajando en el front sin credenciales todavía.
# ============================================================================

# Server-only — NUNCA agregues el prefijo NEXT_PUBLIC_ a esta variable.
# Settings → API → "Project URL" en tu proyecto de Supabase.
# SUPABASE_URL=https://tu-proyecto.supabase.co

# Server-only — NUNCA agregues el prefijo NEXT_PUBLIC_ a esta variable.
# Tiene permisos completos y bypassa RLS; si llegara al navegador,
# cualquiera podría leer/escribir tu base de datos sin restricción.
# Settings → API → "service_role" (sección "Project API keys").
# SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Necesaria para que las Server Components llamen a nuestras rutas
# internas con una URL absoluta. En producción (Vercel), pon la URL
# pública real de tu app.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# Chatwoot — integración de WhatsApp Business (self-hosted).
# Mientras estas tres no estén configuradas, el chat usa
# automáticamente su modo demo (datos en memoria).
# ============================================================================

# URL de tu instancia de Chatwoot (ej: https://chatwoot.tudominio.com).
# CHATWOOT_URL=https://chatwoot.tudominio.com

# API Access Token — Settings → Account → API → Generate token.
# CHATWOOT_API_TOKEN=tu-api-token

# Account ID — aparece en la URL del panel: /app/accounts/{ID}/...
# CHATWOOT_ACCOUNT_ID=1
